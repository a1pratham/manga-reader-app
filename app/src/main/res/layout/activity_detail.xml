<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0B0D14"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="240dp">

                <ImageView
                    android:id="@+id/bannerImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_dark_overlay"/>
            </FrameLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-60dp">

                <ImageView
                    android:id="@+id/coverImage"
                    android:layout_width="110dp"
                    android:layout_height="160dp"
                    android:scaleType="centerCrop"
                    android:elevation="4dp"
                    android:background="#151722"/>

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_marginStart="16dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60dp">

                    <TextView
                        android:id="@+id/titleText"
                        android:text="Title"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="-0.02"
                        android:lineSpacingExtra="2dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/statusText"
                        android:text="Status"
                        android:textColor="#A0A3B5"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/ratingText"
                        android:text="⭐ --"
                        android:textColor="#FFC107"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/chaptersText"
                        android:text="Chapters: --"
                        android:textColor="#A0A3B5"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="4dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/infoTab"
                    android:text="Info"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_primary"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="48dp"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/readTab"
                    android:text="Read"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#8A8D9F"
                    android:background="@drawable/btn_secondary"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="48dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/infoLayout"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/listEditorButton"
                    android:text="Add to Library"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#E2E2E9"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/search_bg"
                    android:layout_width="match_parent"
                    android:layout_marginBottom="24dp"
                    android:layout_height="52dp"/>

                <TextView
                    android:text="GENRES"
                    android:textColor="#6B6E7D"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.08"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/genresText"
                    android:textColor="#E2E2E9"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="SYNOPSIS"
                    android:textColor="#6B6E7D"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.08"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/descriptionText"
                    android:textColor="#C4C6D0"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="32dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/readLayout"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingHorizontal="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/sourceSelector"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:text="Source: MangaPill"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="false"
                    android:textColor="#E2E2E9"
                    android:background="@drawable/search_bg"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/continueButton"
                    android:text="Start Reading"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#E2E2E9"
                    android:background="@drawable/search_bg"
                    android:layout_marginTop="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/prevBtn"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Previous"
                        android:textAllCaps="false"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#E2E2E9"
                        android:background="@drawable/search_bg"/>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/nextBtn"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Next"
                        android:textAllCaps="false"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#E2E2E9"
                        android:background="@drawable/search_bg"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <GridLayout
                    android:id="@+id/chaptersGrid"
                    android:columnCount="4"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="32dp"
                    android:useDefaultMargins="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <View
        android:id="@+id/loaderOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D90B0D14"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/chapterLoader"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FF3366"
        android:visibility="gone" />

</FrameLayout>