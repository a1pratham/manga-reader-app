<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/readerRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="80dp"
        android:paddingBottom="150dp"
        android:scrollbars="none" />

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:gravity="top"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        android:background="@drawable/fade_top_bar">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:padding="4dp"
            app:tint="#E2E2E9" />

        <TextView
            android:id="@+id/chapterTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chapter"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01"
            android:paddingStart="16dp"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageView
            android:id="@+id/menuBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_more"
            android:padding="4dp"
            app:tint="#E2E2E9" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/pageSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="100dp"
        android:layout_marginHorizontal="32dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingVertical="12dp"
        android:background="@drawable/bg_floating_slider"
        android:progressTint="#FF3366"
        android:thumbTint="#FF3366"
        android:max="100"
        android:progress="0" />

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:background="@drawable/fade_bottom_bar"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/prevChapterBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="←  Prev"
            android:textColor="#E2E2E9"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center_vertical|start"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/pageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="1 / 1"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:gravity="center"
            android:paddingHorizontal="24dp" />

        <TextView
            android:id="@+id/nextChapterBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Next  →"
            android:textColor="#E2E2E9"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center_vertical|end"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/loading"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:indeterminateTint="#FF3366"
        android:visibility="gone" />

</FrameLayout>