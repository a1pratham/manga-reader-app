<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_bottom_sheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:text="Edit Library Entry"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="-0.02"
        android:layout_marginBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <AutoCompleteTextView
        android:id="@+id/statusDropdown"
        android:hint="Status (e.g., Reading, Completed)"
        android:textColor="#E2E2E9"
        android:textColorHint="#6B6E7D"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/btn_secondary"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:drawableEnd="@android:drawable/arrow_down_float"
        android:drawableTint="#8A8D9F"
        android:focusable="false"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="52dp"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/progressInput"
            android:hint="Chapters Read"
            android:inputType="number"
            android:textColor="#E2E2E9"
            android:textColorHint="#6B6E7D"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/btn_secondary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="52dp"/>

        <Button
            android:id="@+id/plusButton"
            android:text="+1"
            android:textColor="#FF3366"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            android:background="@drawable/btn_secondary"
            android:layout_marginStart="12dp"
            android:layout_width="72dp"
            android:layout_height="52dp"/>
    </LinearLayout>

    <EditText
        android:id="@+id/scoreInput"
        android:hint="Score (1-10)"
        android:inputType="numberDecimal"
        android:textColor="#E2E2E9"
        android:textColorHint="#6B6E7D"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/btn_secondary"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginTop="12dp"
        android:layout_width="match_parent"
        android:layout_height="52dp"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/startDateButton"
            android:text="Start Date"
            android:textAllCaps="false"
            android:textColor="#E2E2E9"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/btn_secondary"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="52dp"/>

        <Button
            android:id="@+id/endDateButton"
            android:text="End Date"
            android:textAllCaps="false"
            android:textColor="#8A8D9F"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/btn_secondary"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="52dp"/>
    </LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/deleteButton"
            android:text="Remove"
            android:textAllCaps="false"
            android:textColor="#FF3366"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/btn_secondary"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="52dp"/>

        <Button
            android:id="@+id/saveButton"
            android:text="Save Changes"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/btn_primary"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="52dp"/>
    </LinearLayout>

</LinearLayout>