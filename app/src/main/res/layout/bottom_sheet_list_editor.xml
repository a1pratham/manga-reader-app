<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#121212"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- TITLE -->
    <TextView
        android:text="List Editor"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- STATUS -->
    <AutoCompleteTextView
        android:id="@+id/statusDropdown"
        android:hint="Status"
        android:textColor="#FFFFFF"
        android:textColorHint="#888"
        android:background="@drawable/pill_bg"
        android:padding="12dp"
        android:drawableEnd="@android:drawable/arrow_down_float"
        android:focusable="false"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="50dp"/>

    <!-- PROGRESS ROW -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/progressInput"
            android:hint="Progress"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#888"
            android:background="@drawable/pill_bg"
            android:padding="12dp"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="50dp"/>

        <Button
            android:id="@+id/plusButton"
            android:text="+1"
            android:textColor="#FF4081"
            android:background="@drawable/pill_bg"
            android:layout_marginStart="8dp"
            android:layout_width="70dp"
            android:layout_height="50dp"/>
    </LinearLayout>

    <!-- SCORE -->
    <EditText
        android:id="@+id/scoreInput"
        android:hint="Score (1-10)"
        android:inputType="number"
        android:textColor="#FFFFFF"
        android:textColorHint="#888"
        android:background="@drawable/pill_bg"
        android:padding="12dp"
        android:layout_marginTop="12dp"
        android:layout_width="match_parent"
        android:layout_height="50dp"/>

    <!-- DATES -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/startDateButton"
            android:text="Started At"
            android:textColor="#FFFFFF"
            android:background="@drawable/pill_bg"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="50dp"/>

        <Button
            android:id="@+id/endDateButton"
            android:text="Completed At"
            android:textColor="#AAAAAA"
            android:background="@drawable/pill_bg"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="50dp"/>
    </LinearLayout>

    <!-- ACTION BUTTONS -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/deleteButton"
            android:text="Delete"
            android:textColor="#FF4081"
            android:background="@drawable/pill_bg"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="50dp"/>

        <Button
            android:id="@+id/saveButton"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:background="@drawable/pink_pill"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="50dp"/>
    </LinearLayout>

</LinearLayout>